<mvc:View controllerName="vizframechart.controller.MainView"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:l="sap.ui.layout">
    <Page id="page" title="{i18n>title}">
        <content>
            <l:BlockLayout background="Dashboard" visible="true">
                <l:content>
                    <l:BlockLayoutRow>
                        <l:content>
                            <l:BlockLayoutCell id="Cell1" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame1" uiConfig="{application: 'fiori'}" vizType="bar" vizProperties="{title: {text: 'Sales in Month'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/barChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Month" value="{chartModel>Category}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Sales" value="{chartModel>Value}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Sales"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell2" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame2" uiConfig="{application: 'fiori'}" vizType="column" vizProperties="{title: {text: 'Product Quantity'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/columnChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Product" value="{chartModel>Product}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Quantity" value="{chartModel>Quantity}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Quantity"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Product"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell3" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame3" uiConfig="{application: 'fiori'}" vizType="combination" vizProperties="{title: {text: 'Combined Data'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/combinedChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Month" value="{chartModel>Month}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Sales" value="{chartModel>Sales}"></viz.data:MeasureDefinition>
                                                    <viz.data:MeasureDefinition name="Profit" value="{chartModel>Profit}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Sales,Profit"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell4" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame4" uiConfig="{application: 'fiori'}" vizType="stacked_column" vizProperties="{title: {text: 'Demand Status For Next 6 Months'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/stackedColumnData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Month" value="{chartModel>Month}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="ProjectA" value="{chartModel>ProjectA}"></viz.data:MeasureDefinition>
                                                    <viz.data:MeasureDefinition name="ProjectB" value="{chartModel>ProjectB}"></viz.data:MeasureDefinition>
                                                    <viz.data:MeasureDefinition name="ProjectC" value="{chartModel>ProjectC}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="ProjectA,ProjectB,ProjectC"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                        </l:content>
                    </l:BlockLayoutRow>
                    <l:BlockLayoutRow>
                        <l:content>
                            <l:BlockLayoutCell id="Cell5" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame5" uiConfig="{application: 'fiori'}" vizType="pie" vizProperties="{title: {text: 'Department Count'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/pieChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Department" value="{chartModel>Department}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Count" value="{chartModel>Count}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Count"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Department"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell6" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame6" uiConfig="{application: 'fiori'}" vizType="donut" vizProperties="{title: {text: 'Status Distribution'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/donutChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Status" value="{chartModel>Status}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Value" value="{chartModel>Value}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="size" type="Measure" values="Value"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Status"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell7" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame7" uiConfig="{application: 'fiori'}" vizType="bubble" vizProperties="{title: {text: 'Region Distribution'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/bubbleChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Region" value="{chartModel>Region}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Revenue" value="{chartModel>Revenue}"></viz.data:MeasureDefinition>
                                                    <viz.data:MeasureDefinition name="Profit" value="{chartModel>Profit}"></viz.data:MeasureDefinition>
                                                    <viz.data:MeasureDefinition name="Customers" value="{chartModel>Customers}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="valueAxis2" type="Measure" values="Profit"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="bubbleWidth" type="Measure" values="Customers" />
                                            <viz.feeds:FeedItem uid="color" type="Dimension" values="Region" />
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                            <l:BlockLayoutCell id="Cell8" width="1">
                                <l:content>
                                    <viz:VizFrame id="idVizFrame8" uiConfig="{application: 'fiori'}" vizType="line" vizProperties="{title: {text: 'Status Distribution'}, plotArea: {dataLabel: {visible: true}}}">
                                        <viz:dataset>
                                            <viz.data:FlattenedDataset data="{chartModel>/lineChartData}">
                                                <viz.data:dimensions>
                                                    <viz.data:DimensionDefinition name="Month" value="{chartModel>Month}"></viz.data:DimensionDefinition>
                                                </viz.data:dimensions>
                                                <viz.data:measures>
                                                    <viz.data:MeasureDefinition name="Revenue" value="{chartModel>Revenue}"></viz.data:MeasureDefinition>
                                                </viz.data:measures>
                                            </viz.data:FlattenedDataset>
                                        </viz:dataset>
                                        <viz:feeds>
                                            <viz.feeds:FeedItem uid="valueAxis" type="Measure" values="Revenue"></viz.feeds:FeedItem>
                                            <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"></viz.feeds:FeedItem>
                                        </viz:feeds>
                                    </viz:VizFrame>
                                </l:content>
                            </l:BlockLayoutCell>
                        </l:content>
                    </l:BlockLayoutRow>
                </l:content>
            </l:BlockLayout>
        </content>
    </Page>     
</mvc:View>